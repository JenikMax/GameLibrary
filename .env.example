# ─── PostgreSQL ───────────────────────────────────────────
POSTGRES_PASSWORD=change_me_superuser_password
DB_PASSWORD=change_me_app_password

# ─── JWT (подпись токенов) ────────────────────────────────
# Сгенерировать: openssl rand -hex 32
JWT_SECRET=change_me_jwt_secret

# ─── Scraper Encryption Key ───────────────────────────────
# AES-256 base64 ключ для шифрования API-ключей скраперов.
# Сгенерировать: openssl rand -base64 32
SCRAPER_ENCRYPTION_KEY=change_me_encryption_key
