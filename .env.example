# ─── PostgreSQL ───────────────────────────────────────────
POSTGRES_PASSWORD=change_me_superuser_password
DB_PASSWORD=change_me_app_password

# ─── JWT (подпись токенов) ────────────────────────────────
# Сгенерировать: openssl rand -hex 32
JWT_SECRET=change_me_jwt_secret

# ─── Scraper Encryption Key ───────────────────────────────
# AES-256 base64 ключ для шифрования API-ключей скраперов.
# Сгенерировать: openssl rand -base64 32
SCRAPER_ENCRYPTION_KEY=change_me_encryption_key

# ─── CORS (опционально) ───────────────────────────────────
# Разрешённые origin для CORS (через запятую).
# Нужно, если обращаетесь к API напрямую (не через Nginx reverse-proxy на порту 80).
# Пример: http://tnas-e5f0.local:8080,http://192.168.1.100:8080
# CORS_ALLOWED_ORIGINS=http://tnas-e5f0.local:8080

# ─── HTTPS (опционально) ──────────────────────────────────
# Для production замените самоподписанные сертификаты в ./certs/
# на сертификаты Let's Encrypt или свои.
